# NVIDIA API key — free from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# Tavily API key (for cross-portal web search) — free from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Optional: override agent workspace directory
# DOT_AGENT_WORKSPACE=./workspace

# Docker socket (optional, for sandbox mode)
# DOCKER_HOST=unix:///var/run/docker.sock
